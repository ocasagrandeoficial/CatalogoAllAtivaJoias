// Prisma schema — Dê Minas Café
// Banco: PostgreSQL (funciona tanto localmente quanto na Vercel).
// A conexão vem da variável de ambiente DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  order     Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([order])
}

model Product {
  id              String       @id @default(cuid())
  title           String
  description     String
  imageUrl        String
  price           Float
  costPrice       Float        @default(0)
  isAvailable     Boolean      @default(true)
  pricingStrategy String? // markupPercent | marginPercent | fixedProfit | finalPrice
  pricingValue    Float?
  categoryId      String
  category        Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  recipeItems     RecipeItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([categoryId])
}

model Ingredient {
  id               String       @id @default(cuid())
  name             String       @unique
  purchasePrice    Float // custo da embalagem fechada
  purchaseQuantity Float // quantidade contida na embalagem
  unit             String // kg | g | mg | L | ml | un
  recipeItems      RecipeItem[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model RecipeItem {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  quantityUsed Float
  createdAt    DateTime   @default(now())

  @@unique([productId, ingredientId])
  @@index([productId])
  @@index([ingredientId])
}

model Order {
  id             String      @id @default(cuid())
  customerName   String
  customerPhone  String? // WhatsApp da encomenda (opcional)
  waiterName     String?
  status         String      @default("PENDING") // PENDING | COMPLETED
  totalAmount    Float
  advancePayment Float       @default(0) // sinal pago antecipadamente
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@index([createdAt])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity    Int
  priceAtTime Float
  costAtTime  Float   @default(0)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}
